# Supabase — find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# OpenAI — platform.openai.com → API keys
OPENAI_API_KEY=sk-...

# Google Cloud Vision — console.cloud.google.com → Credentials → API key
GOOGLE_VISION_API_KEY=AIza...

# Feature flag — set to false to fall back to Tesseract.js (free, less accurate)
NEXT_PUBLIC_USE_GOOGLE_OCR=true
